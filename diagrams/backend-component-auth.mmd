C4Component
    title Component Diagram - Auth Module

    Container(mw, "Middleware Layer", "Express", "JWT Auth + Role Authorization")

    Container_Boundary(auth, "Auth Module") {
        Component(route, "Auth Route", "Express Router", "POST /register, /login, /logout")
        Component(controller, "Auth Controller", "Express Handler", "Handles auth HTTP requests and responses")
        Component(service, "Auth Service", "Business Logic", "Registration, login with brute-force protection, logout")
        Component(repository, "Auth Repository", "Data Access", "LoginAttempt and AuthToken queries")
        Component(dto, "Auth DTO", "Transfer Object", "toLoginResponseDTO, toRegisterResponseDTO")
        Component(iface, "Auth Interface", "Module Interface", "External API for other modules")
        Component(loginAttemptModel, "LoginAttempt Model", "Mongoose Schema", "userId, success, attemptTime, ipAddress")
        Component(authTokenModel, "AuthToken Model", "Mongoose Schema", "userId, token, expiresAt, isRevoked")
    }

    Container(shared, "Shared Security Services", "Node.js", "Token Blacklist, Login Attempt Tracker, Validators")
    Container(userInterface, "User Interface", "Module Interface", "From Users Module — user lookup and creation")
    ContainerDb(db, "MongoDB", "Database")

    Rel(route, mw, "Applies auth middleware")
    Rel(mw, controller, "Forwards authenticated requests")
    Rel(controller, service, "Calls business logic")
    Rel(controller, dto, "Shapes response data")
    Rel(service, userInterface, "User lookup and creation via interface")
    Rel(service, shared, "Uses security services")
    Rel(repository, loginAttemptModel, "Uses schema")
    Rel(repository, authTokenModel, "Uses schema")
    Rel(repository, db, "Reads/Writes")
    Rel(iface, service, "Delegates to service")
